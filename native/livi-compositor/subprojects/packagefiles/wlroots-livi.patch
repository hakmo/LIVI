+void wlr_wl_output_set_fullscreen(struct wlr_output *output, bool fullscreen) {
+	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
+	assert(wl_output->xdg_toplevel != NULL);
+
+	if (!wl_output->initialized) {
+		return;
+	}
+	if (fullscreen) {
+		xdg_toplevel_set_fullscreen(wl_output->xdg_toplevel, NULL);
+	} else {
+		xdg_toplevel_unset_fullscreen(wl_output->xdg_toplevel);
+	}
+	wl_display_flush(wl_output->backend->remote_display);
+}
+
+void wlr_wl_output_set_minimized(struct wlr_output *output) {
+	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
+	if (wl_output->xdg_toplevel == NULL || !wl_output->initialized) {
+		return;
+	}
+	xdg_toplevel_set_minimized(wl_output->xdg_toplevel);
+	wl_display_flush(wl_output->backend->remote_display);
+}
+
+void wlr_wl_output_begin_move(struct wlr_output *output) {
+	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
+	if (wl_output->xdg_toplevel == NULL || !wl_output->initialized) {
+		return;
+	}
+	struct wlr_wl_backend *backend = wl_output->backend;
+	if (backend->last_button_seat == NULL) {
+		return;
+	}
+	xdg_toplevel_move(wl_output->xdg_toplevel, backend->last_button_seat,
+		backend->last_button_serial);
+	wl_display_flush(backend->remote_display);
+}
+
+void wlr_wl_output_begin_resize(struct wlr_output *output, uint32_t edges) {
+	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
+	if (wl_output->xdg_toplevel == NULL || !wl_output->initialized) {
+		return;
+	}
+	struct wlr_wl_backend *backend = wl_output->backend;
+	if (backend->last_button_seat == NULL) {
+		return;
+	}
+	xdg_toplevel_resize(wl_output->xdg_toplevel, backend->last_button_seat,
+		backend->last_button_serial, edges);
+	wl_display_flush(backend->remote_display);
+}
+
 struct wl_surface *wlr_wl_output_get_surface(struct wlr_output *output) {
 	struct wlr_wl_output *wl_output = get_wl_output_from_output(output);
 	return wl_output->surface;
