+/**
+ * Sets the fullscreen state of a struct wlr_output which is a Wayland toplevel.
+ *
+ * LIVI: lets a nested compositor drive its host output window's fullscreen state,
+ * so app-controlled kiosk/fullscreen fullscreens the real desktop window.
+ */
+void wlr_wl_output_set_fullscreen(struct wlr_output *output, bool fullscreen);
+
+/**
+ * LIVI: minimizes the output's host toplevel (xdg_toplevel.set_minimized).
+ */
+void wlr_wl_output_set_minimized(struct wlr_output *output);
+
+/**
+ * LIVI: begins an interactive move of the output's host toplevel, handed to the
+ * host compositor (xdg_toplevel.move), using the last host pointer button serial.
+ */
+void wlr_wl_output_begin_move(struct wlr_output *output);
+
+/**
+ * LIVI: begins an interactive resize of the output's host toplevel (xdg_toplevel.resize).
+ * edges is a bitmask of enum wlr_edges.
+ */
+void wlr_wl_output_begin_resize(struct wlr_output *output, uint32_t edges);
